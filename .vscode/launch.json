{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current Test File",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
            "args": ["run", "${relativeFile}", "--no-coverage"],
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "test"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug All Tests",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
            "args": ["run", "--no-coverage"],
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "test"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Tests in Watch Mode",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
            "args": ["--watch"],
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "test"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Specific Test",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
            "args": ["run", "${relativeFile}", "-t", "${input:testName}", "--no-coverage"],
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "test"
            },
            "inputs": [
                {
                    "id": "testName",
                    "type": "promptString",
                    "description": "Test name to debug (regex pattern)"
                }
            ]
        }
    ]
}
