	"devDependencies": {
		"@repo/biome-config": "workspace:^",
		"@repo/typescript-config": "workspace:*",
		"@repo/vitest-config": "workspace:*",
		"@types/node": "catalog:",
		"@vitest/coverage-istanbul": "catalog:",
		"tsup": "catalog:",
