{
	"name": "@vgerbot/async",
	"version": "0.0.0",
	"private": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"lint": "biome check --write",
