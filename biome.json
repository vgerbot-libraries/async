{
    "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
    "root": true,
    "files": {
        "ignoreUnknown": false,
        "includes": ["**", "!.output", "!**/.output", "!.vinxi", "!**/.vinxi", "!dist", "!**/dist", "!docs"]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "formatter": {
        "lineWidth": 120,
        "indentStyle": "space",
        "indentWidth": 4
    }
}
